<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.dashboard.DashboardFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="90dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/headerBackground"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:background="@drawable/bg_header_dashboard"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="48dp"
                android:text=""
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Halo, Kiana!" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.8"
                android:text="@string/current_date"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/tvGreeting"
                app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfile"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="48dp"
                android:layout_marginEnd="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerCrop"
                android:src="@drawable/sample_profile"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <ImageButton
                android:id="@+id/btnNotification"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_icon_circle_alpha"
                android:contentDescription="@string/menu_notifikasi"
                android:src="@drawable/ic_notification"
                app:layout_constraintBottom_toBottomOf="@id/ivProfile"
                app:layout_constraintEnd_toStartOf="@id/ivProfile"
                app:layout_constraintTop_toTopOf="@id/ivProfile"
                app:tint="@color/white" />

            <!-- Shimmer Loading -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvDate"
                app:shimmer_auto_start="false"
                app:shimmer_duration="1200">

                <include layout="@layout/layout_skeleton_dashboard" />
            </com.facebook.shimmer.ShimmerFrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/card_blue_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/tvDate"
                app:strokeColor="@color/card_stroke_alpha"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvOrgName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/badgeKetua"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_badge_alpha"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="2dp"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/tvOrgName"
                        app:layout_constraintTop_toBottomOf="@id/tvOrgName" />

                    <TextView
                        android:id="@+id/tvActiveMembers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:alpha="0.8"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toBottomOf="@id/badgeKetua"
                        app:layout_constraintStart_toEndOf="@id/badgeKetua"
                        app:layout_constraintTop_toTopOf="@id/badgeKetua" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:weightSum="3"
                        app:layout_constraintTop_toBottomOf="@id/badgeKetua">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/card_bg_alpha"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="10dp">

                                <TextView
                                    android:id="@+id/tvRapatCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/white"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RAPAT"
                                    android:textColor="@color/white"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:alpha="0.7"
                                    android:text="minggu ini"
                                    android:textColor="@color/white"
                                    android:textSize="9sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="3dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/card_bg_alpha"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="10dp">

                                <TextView
                                    android:id="@+id/tvTugasCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/white"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="TUGAS"
                                    android:textColor="@color/white"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:alpha="0.7"
                                    android:text="aktif"
                                    android:textColor="@color/white"
                                    android:textSize="9sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/card_bg_alpha"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="10dp">

                                <TextView
                                    android:id="@+id/tvDocCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/white"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DOKUMEN"
                                    android:textColor="@color/white"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:alpha="0.7"
                                    android:text="total"
                                    android:textColor="@color/white"
                                    android:textSize="9sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/mainContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_content_rounded"
                android:paddingTop="24dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/cardOrg"
                tools:visibility="visible">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAdminMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_menu_title"
                            android:textColor="@color/text_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:id="@+id/btnKelolaAnggota"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.imageview.ShapeableImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@color/badge_bg_blue"
                                    android:padding="12dp"
                                    android:src="@drawable/ic_user"
                                    app:shapeAppearanceOverlay="@style/CircleImage"
                                    app:tint="@color/primary_dark" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:gravity="center"
                                    android:text="@string/menu_kelola_anggota"
                                    android:textColor="@color/text_dark"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btnUndangAnggota"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.imageview.ShapeableImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@color/badge_bg_blue"
                                    android:padding="12dp"
                                    android:src="@drawable/ic_add"
                                    app:shapeAppearanceOverlay="@style/CircleImage"
                                    app:tint="@color/primary_dark" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:gravity="center"
                                    android:text="@string/menu_undang_anggota"
                                    android:textColor="@color/text_dark"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/btnUploadDoc"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:orientation="vertical">

                                <com.google.android.material.imageview.ShapeableImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@color/badge_bg_blue"
                                    android:padding="12dp"
                                    android:src="@drawable/ic_document"
                                    app:shapeAppearanceOverlay="@style/CircleImage"
                                    app:tint="@color/primary_dark" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:gravity="center"
                                    android:text="@string/menu_upload_doc"
                                    android:textColor="@color/text_dark"
                                    android:textSize="10sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:id="@+id/indicatorRapat"
                    android:layout_width="4dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="24dp"
                    android:background="@color/accent_yellow"
                    app:layout_constraintBottom_toBottomOf="@id/tvNextMeeting"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvNextMeeting" />

                <TextView
                    android:id="@+id/tvNextMeeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/next_meeting"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/indicatorRapat"
                    app:layout_constraintTop_toBottomOf="@id/cardAdminMenu" />

                <TextView
                    android:id="@+id/btnSeeAllRapat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="24dp"
                    android:text="@string/see_all"
                    android:textColor="@color/primary_light"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tvNextMeeting"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvNextMeeting" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMeeting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tvNextMeeting">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <!-- Left Side: Date Badge -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardDateBadge"
                            android:layout_width="70dp"
                            android:layout_height="80dp"
                            app:cardBackgroundColor="#FDF5E6"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvMeetingDayName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textColor="@color/accent_yellow"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvMeetingDateNumber"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textColor="@color/accent_yellow"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvMeetingMonthYear"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textColor="@color/accent_yellow"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Center: Meeting Details -->
                        <TextView
                            android:id="@+id/tvMeetingTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text=""
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/cardDateBadge"
                            app:layout_constraintTop_toTopOf="@id/cardDateBadge" />

                        <!-- Status Row -->
                        <LinearLayout
                            android:id="@+id/layoutStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="@id/tvMeetingTitle"
                            app:layout_constraintStart_toStartOf="@id/tvMeetingTitle"
                            app:layout_constraintTop_toBottomOf="@id/tvMeetingTitle">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_shield"
                                app:tint="#FF9800" />

                            <TextView
                                android:id="@+id/tvMeetingStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text=""
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <!-- Location Row -->
                        <LinearLayout
                            android:id="@+id/layoutLocation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="@id/tvMeetingTitle"
                            app:layout_constraintStart_toStartOf="@id/tvMeetingTitle"
                            app:layout_constraintTop_toBottomOf="@id/layoutStatus">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_location_small"
                                app:tint="#2196F3" />

                            <TextView
                                android:id="@+id/tvMeetingLoc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text=""
                                android:textColor="@color/text_muted"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <!-- Right Side/Bottom: Avatar Stack -->
                        <LinearLayout
                            android:id="@+id/layoutAvatars"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/cardDateBadge">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/ivAvatar1"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/avatar_1"
                                app:shapeAppearanceOverlay="@style/CircleImage" />

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/ivAvatar2"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginStart="-8dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/avatar_2"
                                app:shapeAppearanceOverlay="@style/CircleImage" />

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/ivAvatar3"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginStart="-8dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/avatar_3"
                                app:shapeAppearanceOverlay="@style/CircleImage" />

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardMoreMembers"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginStart="-8dp"
                                app:cardBackgroundColor="@color/background_gray"
                                app:cardCornerRadius="14dp"
                                app:cardElevation="0dp">

                                <TextView
                                    android:id="@+id/tvMoreMembers"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="+2"
                                    android:textColor="@color/text_muted"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <!-- Action Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMeetingDetail"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:paddingHorizontal="16dp"
                            android:text="@string/see_detail"
                            android:textColor="@color/primary_dark"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:backgroundTint="#E6F0FA"
                            app:cornerRadius="18dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/layoutAvatars" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <View
                    android:id="@+id/indicatorTugas"
                    android:layout_width="4dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:background="@color/primary_dark"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cardMeeting" />

                <TextView
                    android:id="@+id/tvLatestTasks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/latest_tasks"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/indicatorTugas"
                    app:layout_constraintStart_toEndOf="@id/indicatorTugas"
                    app:layout_constraintTop_toTopOf="@id/indicatorTugas" />

                <TextView
                    android:id="@+id/btnSeeAllTugas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="24dp"
                    android:text="@string/see_all"
                    android:textColor="@color/primary_light"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tvLatestTasks"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvLatestTasks" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false"
                    app:layout_constraintTop_toBottomOf="@id/tvLatestTasks"
                    tools:listitem="@layout/item_task" />

                <View
                    android:id="@+id/indicatorDocs"
                    android:layout_width="4dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:background="@color/primary_dark"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rvTasks" />

                <TextView
                    android:id="@+id/tvLatestDocs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/latest_docs"
                    android:textColor="@color/text_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/indicatorDocs"
                    app:layout_constraintStart_toEndOf="@id/indicatorDocs"
                    app:layout_constraintTop_toTopOf="@id/indicatorDocs" />

                <TextView
                    android:id="@+id/btnSeeAllDocs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="24dp"
                    android:text="@string/see_all"
                    android:textColor="@color/primary_light"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tvLatestDocs"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvLatestDocs" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDocs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@id/tvLatestDocs"
                    tools:listitem="@layout/item_document" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
