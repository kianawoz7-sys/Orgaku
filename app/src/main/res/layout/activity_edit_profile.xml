<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back_small"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/text_dark"
                android:contentDescription="@string/skip" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/edit_profile_title"
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Profile Image Selection -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/profileImageContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_profile"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:padding="4dp"
                android:scaleType="centerCrop"
                android:src="@drawable/avatar_1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/divider"
                app:strokeWidth="2dp"
                android:contentDescription="@string/onboarding_image" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_change_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardBackgroundColor="@color/primary_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:layout_constraintBottom_toBottomOf="@id/iv_profile"
                app:layout_constraintEnd_toEndOf="@id/iv_profile"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/white"
                    android:contentDescription="@string/edit_profile_title" />
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Full Name Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.05" />

        <EditText
            android:id="@+id/edt_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/full_name"
            android:inputType="textPersonName"
            android:padding="16dp"
            android:background="@drawable/bg_input"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:layout_marginBottom="20dp"
            android:autofillHints="name" />

        <!-- Email Field (Read-only) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_email_readonly"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.05" />

        <EditText
            android:id="@+id/edt_email"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:enabled="false"
            android:inputType="textEmailAddress"
            android:padding="16dp"
            android:background="@drawable/bg_input"
            android:textSize="16sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginBottom="20dp"
            android:alpha="0.6"
            android:autofillHints="emailAddress" />

        <!-- NIM Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_nim"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.05" />

        <EditText
            android:id="@+id/edt_nim"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/hint_nim"
            android:inputType="number"
            android:padding="16dp"
            android:background="@drawable/bg_input"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:layout_marginBottom="20dp"
            android:autofillHints="none" />

        <!-- Phone Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_phone"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.05" />

        <EditText
            android:id="@+id/edt_phone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/hint_phone"
            android:inputType="phone"
            android:padding="16dp"
            android:background="@drawable/bg_input"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:layout_marginBottom="20dp"
            android:autofillHints="phoneNumber" />

        <!-- Organization Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_organization"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.05" />

        <EditText
            android:id="@+id/edt_organization"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/hint_organization"
            android:inputType="text"
            android:padding="16dp"
            android:background="@drawable/bg_input"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:layout_marginBottom="32dp"
            android:autofillHints="none" />

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_save_changes"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/btn_primary"
            app:backgroundTint="@null"
            app:cornerRadius="16dp" />

    </LinearLayout>

</ScrollView>